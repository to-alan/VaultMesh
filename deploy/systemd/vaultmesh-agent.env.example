# The control plane must be exposed through a trusted HTTPS reverse proxy.
VAULTMESH_SERVER_URL=https://backup.example.com

# Required only for first start. Remove it after enrollment succeeds.
VAULTMESH_ENROLLMENT_TOKEN=enroll_replace_me

# Optional executable overrides.
VAULTMESH_RESTIC_PATH=restic
VAULTMESH_MYSQLDUMP_PATH=mysqldump
VAULTMESH_PG_DUMP_PATH=pg_dump
VAULTMESH_DOCKER_PATH=docker
