# Generate with: openssl rand -base64 32
VAULTMESH_MASTER_KEY=

# Administrator console login. Generate the password with: openssl rand -hex 16
VAULTMESH_ADMIN_USERNAME=admin
VAULTMESH_ADMIN_PASSWORD=

# Set true when the browser reaches the API through HTTPS.
VAULTMESH_COOKIE_SECURE=false

# Use a long random password. It is only used by the local PostgreSQL container.
POSTGRES_PASSWORD=

# API and Web are independent services. These defaults bind both to loopback.
VAULTMESH_API_PORT=8080
VAULTMESH_WEB_PORT=3000

# URL used by the browser to reach the API. Production deployments should use HTTPS.
VAULTMESH_PUBLIC_API_URL=http://127.0.0.1:8080

# Exact browser origins allowed to call the API, comma-separated and without trailing slashes.
VAULTMESH_ALLOWED_ORIGINS=http://127.0.0.1:3000

# Passkeys/WebAuthn. RP ID defaults to the hostname of the first allowed origin,
# and RP origins default to VAULTMESH_ALLOWED_ORIGINS. Set these explicitly when
# the browser uses more than one trusted origin. Production origins require HTTPS.
VAULTMESH_WEBAUTHN_RP_ID=127.0.0.1
VAULTMESH_WEBAUTHN_RP_NAME=VaultMesh
VAULTMESH_WEBAUTHN_RP_ORIGINS=http://127.0.0.1:3000
