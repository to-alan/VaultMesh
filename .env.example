# Generate with: openssl rand -base64 32
VAULTMESH_MASTER_KEY=

# Generate with: openssl rand -hex 32
VAULTMESH_ADMIN_TOKEN=

# Use a long random password. It is only used by the local PostgreSQL container.
POSTGRES_PASSWORD=

# Bind to loopback by default. Put Caddy/Nginx/Traefik with TLS in front of it.
VAULTMESH_HTTP_PORT=8080
